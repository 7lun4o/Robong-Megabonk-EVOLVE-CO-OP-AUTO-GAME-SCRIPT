local function saveLocalConfig()
    local data = {Config = Config, Weapons = {}, Perks = {}, Evolves = {}}
    for _, v in ipairs(upgradesConfig.weapons) do data.Weapons[v.id] = v.enabled end
    for _, v in ipairs(upgradesConfig.perks) do data.Perks[v.id] = v.enabled end
    for _, v in ipairs(upgradesConfig.evolves) do data.Evolves[v.id] = v.enabled end
    pcall(function()
        if writefile then writefile(FILE_NAME, HttpService:JSONEncode(data)) end
    end)
end

local function loadLocalConfig()
    local data
    pcall(function()
        if readfile and isfile and isfile(FILE_NAME) then
            data = HttpService:JSONDecode(readfile(FILE_NAME))
        end
    end)
    if data then
        if data.Config then for k, v in pairs(data.Config) do Config[k] = v end end
        if data.Weapons then
            for _, v in ipairs(upgradesConfig.weapons) do
                if data.Weapons[v.id] ~= nil then v.enabled = data.Weapons[v.id] end
            end
        end
        if data.Perks then
            for _, v in ipairs(upgradesConfig.perks) do
                if data.Perks[v.id] ~= nil then v.enabled = data.Perks[v.id] end
            end
        end
        if data.Evolves then
            for _, v in ipairs(upgradesConfig.evolves) do
                if data.Evolves[v.id] ~= nil then v.enabled = data.Evolves[v.id] end
            end
        end
        return true
    end
    return false
end

local function isUpgradeEnabled(id)
    if not id then return false end
    id = id:lower()
    for _, cat in pairs(upgradesConfig) do
        for _, up in ipairs(cat) do
            if up.id:lower() == id or id:find(up.id:lower()) then return up.enabled end
        end
    end
    return false
end

local function isEvolution(id)
    id = id:lower()
    for _, up in ipairs(upgradesConfig.evolves) do
        if up.id:lower() == id or id:find(up.id:lower()) then return true end
    end
    return false
end

local function findBestUpgrade(upgrades)
    local matches = {}
    for _, upgrade in ipairs(upgrades) do
        if type(upgrade) == "table" and upgrade.ID and isUpgradeEnabled(upgrade.ID) then 
            table.insert(matches, upgrade) 
        end
    end
    table.sort(matches, function(a, b)
        local aId = a.ID:lower()
        local bId = b.ID:lower()
        local aPriority = isEvolution(aId) and 5 or (tierWeights[aId] or 0)
        local bPriority = isEvolution(bId) and 5 or (tierWeights[bId] or 0)
        if aPriority ~= bPriority then return aPriority > bPriority end
        return (a.Level or 0) < (b.Level or 0)
    end)
    return matches[1]
end

local function getGold()
    local ok, val = pcall(function() return player.leaderstats.Gold.Value end)
    return ok and val or 0
end

local function getRerollCost()
    local ok, label = pcall(function() return player.PlayerGui.UpgradeScreen.MainContainer.Footer.RollButton.TextLabel.Text end)
    if not ok then return math.huge end
    local numStr = label:match("%d+")
    return numStr and tonumber(numStr) or math.huge
end

