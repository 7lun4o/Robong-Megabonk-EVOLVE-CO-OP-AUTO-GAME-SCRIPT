task.spawn(function()
    tracerBeam = workspace:FindFirstChild("ChestTracerBeam") or Instance.new("Beam")
    tracerBeam.Name = "ChestTracerBeam"
    tracerBeam.Width0 = 0.15 tracerBeam.Width1 = 0.15
    tracerBeam.Color = ColorSequence.new(getThemeColor())
    tracerBeam.FaceCamera = true tracerBeam.Parent = workspace

    local path = PathfindingService:CreatePath({AgentRadius = 3, AgentHeight = 5, AgentCanJump = true})
    local currentChest, waypoints, currentWaypointIndex, lastPathTime = nil, {}, 1, 0

    while true do
        task.wait(0.05)
        if isAlive and Config.AutoChest then
            pcall(function()
                local char = player.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local hum = char and char:FindFirstChildOfClass("Humanoid")
                
                if hrp and hum and hum.Health > 0 then
                    local closestChest, minDist = nil, math.huge
                    for _, part in ipairs(cachedChests) do
                        if part and part:IsDescendantOf(workspace) then
                            local dist = (hrp.Position - part.Position).Magnitude
                            if dist < minDist and dist <= Config.MaxChestDistance then
                                minDist = dist closestChest = part
                            end
                        end
                    end
                    
                    if closestChest then
                        if closestChest ~= currentChest or tick() - lastPathTime > 1 then
                            currentChest = closestChest
                            path:ComputeAsync(hrp.Position, closestChest.Position)
                            if path.Status == Enum.PathStatus.Success then
                                waypoints = path:GetWaypoints() currentWaypointIndex = 2 lastPathTime = tick()
                            else
                                waypoints = {}
                            end
                        end

                        if #waypoints > 0 and currentWaypointIndex <= #waypoints then
                            local targetWaypoint = waypoints[currentWaypointIndex]
                            local wpDist = (hrp.Position - targetWaypoint.Position).Magnitude
                            if wpDist < 4 then
                                currentWaypointIndex = currentWaypointIndex + 1
                                if currentWaypointIndex <= #waypoints then targetWaypoint = waypoints[currentWaypointIndex] end
                            end

                            if targetWaypoint then
                                if targetWaypoint.Action == Enum.PathWaypointAction.Jump then hum.Jump = true end
                                local dir = (targetWaypoint.Position - hrp.Position).Unit
                                local perp = Vector3.new(-dir.Z, 0, dir.X)
                                local sway = math.sin(tick() * 5) * 1.2
                                local targetPos = targetWaypoint.Position
                                if minDist >= 12 then targetPos = targetPos + (perp * sway) end
                                hum:MoveTo(targetPos)
                            else
                                hum:MoveTo(closestChest.Position)
                            end
                        else
                            hum:MoveTo(closestChest.Position)
                        end
                        
                        if Config.ChestTracers then
                            local att0 = hrp:FindFirstChild("ChestTracerAtt") or Instance.new("Attachment", hrp) att0.Name = "ChestTracerAtt"
                            local att1 = closestChest:FindFirstChild("ChestTracerAtt") or Instance.new("Attachment", closestChest) att1.Name = "ChestTracerAtt"
                            tracerBeam.Attachment0 = att0 tracerBeam.Attachment1 = att1 tracerBeam.Enabled = true
                        else
                            tracerBeam.Enabled = false
                        end
                        
                        if minDist < 15 then
                            local prompt = closestChest:FindFirstChildWhichIsA("ProximityPrompt", true) or closestChest.Parent:FindFirstChildWhichIsA("ProximityPrompt", true)
                            if prompt and fireproximityprompt then fireproximityprompt(prompt) end
                            if firetouchinterest then
                                firetouchinterest(hrp, closestChest, 0) task.wait(0.01) firetouchinterest(hrp, closestChest, 1)
                            end
                        end
                    else
                        tracerBeam.Enabled = false
                    end
                end
            end)
        else
            tracerBeam.Enabled = false
        end
    end
end)
