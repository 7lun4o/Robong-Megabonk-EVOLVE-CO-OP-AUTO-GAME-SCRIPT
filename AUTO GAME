local pickerEnabled = false
function onUpgradeScreen(upgrades)
    if not isAlive or not pickerEnabled or type(upgrades) ~= "table" then return end
    if Config.SpamDelay > 0 then task.wait(Config.SpamDelay) end

    local bestPick = findBestUpgrade(upgrades)
    if bestPick then
        SelectUpgrade:FireServer(bestPick.ID)
        if pickerTierLabel then pickerTierLabel.Text = "Upgrade: " .. bestPick.ID end
        if pickerActionLabel then 
            pickerActionLabel.Text = "Action: Selected ✅"
            pickerActionLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
        end
        if pickerLastLabel then pickerLastLabel.Text = "Last: " .. bestPick.ID end
        return
    end

    local gold = getGold()
    local cost = getRerollCost()

    if Config.AutoReroll and cost ~= math.huge and gold >= cost then
        RerollUpgrade:FireServer()
